DATABASE_URL=postgresql://user:password@localhost:5432/hoa_tracker
# JWT signing secret — REQUIRED in production (JWT_SECRET also accepted)
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
# Optional: AI-drafted violation letters (falls back to a built-in template)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
# Optional: comma-separated allowed frontend origins (default *)
CORS_ORIGINS=*
ENVIRONMENT=development

# --- Email delivery (violation notices + password-reset links) ---
# Recommended: Brevo (brevo.com). Free tier = 300 emails/day and it sends over
# HTTPS, so it works on hosts that block outbound SMTP ports (Render/Railway
# free tiers do). No domain required to start: sign up, verify a sender email
# (Senders & IPs > add a sender, click the confirmation link), then create an
# API key under "SMTP & API > API Keys".
BREVO_API_KEY=
BREVO_SENDER_EMAIL=you@example.com   # the sender address you verified in Brevo
BREVO_SENDER_NAME=ViolationTrack     # default From name; each notice overrides it with the HOA's name
# Base URL used to build password-reset links
FRONTEND_URL=https://your-frontend.vercel.app

# Alternative: raw SMTP. Only works where outbound SMTP ports are open — NOT on
# Render/Railway free tiers. Used only when BREVO_API_KEY is empty.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
