DATABASE_URL=postgresql://user:password@localhost:5432/hoa_tracker
# JWT signing secret — REQUIRED in production (JWT_SECRET also accepted)
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
# Optional: AI-drafted violation letters (falls back to a built-in template)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
# Optional: comma-separated allowed frontend origins (default *)
CORS_ORIGINS=*
ENVIRONMENT=development
# Optional: server-side notice delivery + password-reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FRONTEND_URL=https://your-frontend.vercel.app
